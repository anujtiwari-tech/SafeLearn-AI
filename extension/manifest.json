{
  "manifest_version": 3,
  "name": "SafeLearn AI - Student Cybersecurity",
  "version": "1.1.0",
  "description": "AI-powered cybersecurity that explains threats in plain English. Protects students from phishing, malware, and data misuse.",
  
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "webRequest",
    "webNavigation",
    "alarms",
    "notifications"
  ],
  
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:5173/*",
    "https://*/*",
    "https://mail.google.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*"
  ],
  
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://mail.google.com/*"],
      "js": ["src/content/gmail-scanner.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://outlook.live.com/*",
        "*://outlook.office.com/*",
        "*://outlook.office365.com/*"
      ],
      "js": ["src/content/outlook-scanner.js"],
      "run_at": "document_idle"
    }
  ],
  
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SafeLearn AI"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["src/pages/blocked.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}